{
  "name": "ibge-br-mcp",
  "version": "3.0.2",
  "mcpName": "io.github.SidneyBissoli/ibge-br-mcp",
  "description": "MCP server giving AI assistants live, sourced access to Brazilian public data — geography, census, economy and health — from the official IBGE APIs. Exact figures with provenance, not approximations.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ibge-br-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/cloud-run.js",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && node dist/cloud-run.js",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ibge",
    "brasil",
    "brazil",
    "localidades",
    "sidra",
    "nomes",
    "estados",
    "municipios",
    "censo",
    "populacao",
    "malhas",
    "geojson",
    "pnad",
    "pib",
    "pesquisas",
    "mcp-server",
    "datasus",
    "ipca",
    "cidades",
    "demografia",
    "geografia",
    "estatistica",
    "dados-abertos",
    "open-data"
  ],
  "author": "Sidney da Silva Pereira Bissoli",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SidneyBissoli/ibge-br-mcp.git"
  },
  "homepage": "https://github.com/SidneyBissoli/ibge-br-mcp#readme",
  "bugs": {
    "url": "https://github.com/SidneyBissoli/ibge-br-mcp/issues"
  }
}
